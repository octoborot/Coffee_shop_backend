generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum AdminRole {
  ADMIN
  STAFF
}

enum MembershipLevel {
  Diamond
  Gold
  Silver
}

enum ProductCategory {
  Coffee
  Tea
  Juice
  Pastry
}

enum ProductStatus {
  Available
  OutOfStock @map("Out of Stock")
}

enum OrderType {
  Delivery
  Pickup
}

enum OrderStatus {
  New
  Preparing
  Delivering
  Delivered
  Cancelled
}

enum PaymentStatus {
  PAID
  UNPAID
  REFUNDED
}

enum NotificationType {
  promo
  order
  news
}

model AdminUser {
  id            String    @id @default(uuid()) @db.Uuid
  username      String    @unique @db.VarChar
  password_hash String    @db.VarChar
  role          AdminRole

  @@map("admin_users")
}

model Customer {
  id             String           @id @default(uuid()) @db.Uuid
  zalo_id        String           @unique @db.VarChar
  name           String           @db.VarChar
  phone          String?          @unique @db.VarChar
  email          String?          @unique @db.VarChar
  avatar_text    String?          @db.VarChar
  member_card_id String?          @db.VarChar
  membership     MembershipLevel?
  points         Int              @default(0)
  last_purchase  DateTime?        @db.Timestamp()
  created_at     DateTime         @default(now()) @db.Timestamp()

  orders        Order[]
  notifications Notification[]

  @@map("customers")
}

model Product {
  id         String          @id @default(uuid()) @db.Uuid
  name       String          @db.VarChar
  subname    String?         @db.VarChar
  category   ProductCategory
  price      Decimal         @db.Decimal
  price_vnd  Int
  image      String?         @db.Text
  status     ProductStatus   @default(Available)
  details    String?         @db.Text
  created_at DateTime        @default(now()) @db.Timestamp()
  updated_at DateTime        @updatedAt @db.Timestamp()

  orderItems OrderItem[]

  @@map("products")
}

model Order {
  id              String        @id @db.VarChar // e.g., #BB-2094
  customer_id     String?       @db.Uuid
  customer_name   String?       @db.VarChar
  customer_phone  String?       @db.VarChar
  type            OrderType
  status          OrderStatus   @default(New)
  payment_status  PaymentStatus @default(UNPAID)
  total_price     Decimal       @db.Decimal
  total_price_vnd Int
  note            String?       @db.Text
  address         String?       @db.Text
  created_at      DateTime      @default(now()) @db.Timestamp()
  updated_at      DateTime      @updatedAt @db.Timestamp()

  customer Customer?   @relation(fields: [customer_id], references: [id])
  items    OrderItem[]

  @@map("orders")
}

model OrderItem {
  id         String  @id @default(uuid()) @db.Uuid
  order_id   String  @db.VarChar
  product_id String? @db.Uuid
  name       String  @db.VarChar
  quantity   Int
  price      Decimal @db.Decimal
  price_vnd  Int
  options    Json?   @db.JsonB // e.g. {"size": "M", "sweetness": "50%", "ice": "100%"}

  order   Order    @relation(fields: [order_id], references: [id])
  product Product? @relation(fields: [product_id], references: [id])

  @@map("order_items")
}

model BloomRule {
  id          String @id @default(uuid()) @db.Uuid
  name        String @db.VarChar
  description String @db.Text
  icon        String @db.VarChar
  points      String @db.VarChar
  color       String @db.VarChar

  @@map("bloom_rules")
}

model Banner {
  id        String  @id @default(uuid()) @db.Uuid
  tag       String  @db.VarChar
  title     String  @db.VarChar
  image     String  @db.Text
  is_active Boolean @default(true)

  @@map("banners")
}

model Notification {
  id          String           @id @default(uuid()) @db.Uuid
  customer_id String?          @db.Uuid
  title       String           @db.VarChar
  description String           @db.Text
  type        NotificationType
  image       String?          @db.Text
  is_read     Boolean          @default(false)
  created_at  DateTime         @default(now()) @db.Timestamp()

  customer Customer? @relation(fields: [customer_id], references: [id])

  @@map("notifications")
}
